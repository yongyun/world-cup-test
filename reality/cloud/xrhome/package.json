    "clean": "gulp clean && npm ci --legacy-peer-deps",
    "postinstall": "patch-package",
    "generate-studio-schema": "npx ts-node tools/generate-studio-schema.ts > src/client/studio/generated-schema.ts",
    "test": "NODE_ENV=test ts-mocha test/**-test.* --reporter=dot",
    "test-serial": "NODE_ENV=test ts-mocha test/**-test.* --no-parallel",
    "test-file": "NODE_ENV=test ts-mocha",
    "test-file-serial": "NODE_ENV=test ts-mocha --no-parallel",
    "test-build-report": "NODE_ENV=test JUNIT_REPORT_NAME=XRhome-test JUNIT_REPORT_PATH=./test-report.xml mocha --reporter mocha-jenkins-reporter",
    "ts:check": "npx ts-node ./tools/ts/check.ts $(git merge-base HEAD main)",
    "ts:check-file": "./tools/ts/check-file.sh",
    "sort-translations": "find src/client/i18n/en-US -type f | grep -E \"\\.json$\" | xargs npx ts-node tools/sort-translation.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
