{
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "module": "esnext",
    "checkJs": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "target": "es6"
  },
  "include": ["./src/*.ts", "./src/**/*.ts", "./src/*.js", "./src/**/*.js"],
  "exclude": ["node_modules"]
}
