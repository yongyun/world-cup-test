{
  "compilerOptions": {
    "target": "es2020",
    "baseUrl": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "outDir": "./dist/",
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "paths": {
      "@8thwall/ecs": [
        ".gen/types/ecs.d.ts"
      ]
    },
    "types": [
      "@8thwall/build"
    ]
  },
  "include": [
    "src",
    ".gen/types/**/*"
  ]
}
