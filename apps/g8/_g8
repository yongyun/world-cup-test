#compdef g8

function _g8 {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- : *)'{-h,--help}'[Display help information]' \
        '(-h --help)1: :_geight_commands' \
        '(-h --help)*:: :->command_args'

    case $state in
        command_args)
        (( $+functions[_geight_${words[1]}_args] )) && _geight_${words[1]}_args
        ;;
    esac
}

(( $+functions[_geight_commands] )) ||
_geight_commands() {
    local repo_commands changeset_commands misc_commands
    repo_commands=(
        'client:Create or change client'
        'newclient:[Deprecated] Create new client'
        'clone:Clone a remote repository'
        'dry-sync:Dry sync to uncover mergeability'
        'fetch-new-clients:Fetch new clients'
        'info:Get information about the repository'
        'log:Commit history for repo'
        'sync:Sync and rebase client'
        'initial-commit:Create the initial commit on a new repo'
        'status:List files and statuses'
        'ls:List files'
    )
    changeset_commands=(
        'newchange:Create new changeset'
        'add:Add files to changeset'
        'unadd:Remove files from changeset'
        'change:Query changeset'
        'update:Update changesets'
        'land:Land a changeset'
        'diff:Diff between changes'
        'patch:Patch changes'
        'files:Move files in and out of changesets'
        'revert:Revert files'
        'save:Save work'
        'send:Send a changeset for review'
        'pr:Open PR in browser'
        'mr:Open MR in browser'
    )
    misc_commands=(
        'keep-house:Perform house keeping'
    )
    _describe "commands" repo_commands -- changeset_commands -- misc_commands
}

(( $+functions[_geight_add_args] )) ||
