# List of <target_label (as the file basename without extension), target_file_path> pairs
S2_TEST_ITEMS = [
    (
        f.split("/")[-1].split(".")[0],
        f,
    )
    for f in S2_TEST_FILES
]

filegroup(
    name = "s2testing",
    srcs = [
        "src/s2/s2builderutil_testing.cc",
        "src/s2/s2shapeutil_testing.cc",
        "src/s2/s2testing.cc",
        "src/s2/thread_testing.cc",
    ],
)

[cc_test(
    name = target_label,
    srcs = [
        file_name,
        ":s2testing",
    ],
    deps = [
        ":s2",
        "@com_google_googletest//:gtest_main",
    ],
) for target_label, file_name in S2_TEST_ITEMS]
