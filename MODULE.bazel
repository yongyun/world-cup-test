MODULE_NAME = "the8thwall"

module(
    name = MODULE_NAME,
    version = "1.0",
    compatibility_level = 1,
)

workspace_env = use_repo_rule("//bzl/crosstool:workspace-env.bzl", "workspace_env")

workspace_env(
    name = "workspace-env",
    workspace_name = MODULE_NAME,
)

bazel_dep(name = "platforms", version = "0.0.11", repo_name = "platforms")
single_version_override(
    module_name = "platforms",
    version = "0.0.11",
)

bazel_dep(name = "rules_foreign_cc", version = "0.9.0", repo_name = "rules_foreign_cc")
single_version_override(
    module_name = "rules_foreign_cc",
    version = "0.9.0",
)

bazel_dep(name = "abseil-cpp", version = "20230802.0.bcr.1", repo_name = "com_google_absl")

# lts 20230802.2, patch: adds MODULE.bazel file to abseil-cpp
git_override(
    module_name = "abseil-cpp",
    commit = "929c17cf481222c35ff1652498994871120e832a",
    patches = [
        "//third_party/abseil-cpp:module_dot_bazel.patch",
    ],
    remote = "https://github.com/abseil/abseil-cpp.git",
)

bazel_dep(name = "rules_java", version = "7.6.1", repo_name = "rules_java")
bazel_dep(name = "rules_apple", version = "3.1.1", repo_name = "build_bazel_rules_apple")
bazel_dep(name = "zlib", version = "1.3", repo_name = "zlib")
git_override(
    module_name = "zlib",
    commit = "04f42ceca40f73e2978b50e93806c2a18c1281fc",
    patch_strip = 1,
    patches = [
        "//third_party/zlib:zlib.git_override_bzlmod.patch",
    ],
    remote = "https://github.com/madler/zlib.git",
)

bazel_dep(name = "protobuf", version = "25.3-nia", repo_name = "com_google_protobuf")
archive_override(
    module_name = "protobuf",
    integrity = "sha256-Z0r7LQ2q8maFm0+o+fHAUdusVoAKYh37SNIwKEKWC/4=",
    strip_prefix = "protobuf-25.3-nia-v0.3",
    urls = ["https://huggingface.co/datasets/8thWall/bazel-dependencies/resolve/main/protobuf/protobuf-25.3-nia-v0.3.tar"],
)

bazel_dep(name = "llvm-project", version = "17.0.3")

