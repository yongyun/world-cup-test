+TFL_CAPI_EXPORT uint8_t* TfLiteGpuDelegateGetKernelCache(const TfLiteNode& node,
+                                                         size_t* size) {
+    auto delegate = reinterpret_cast<tflite::gpu::DelegateKernel*>(node.user_data);
+    if (delegate) {
+        auto cache = delegate->GetSerializedKernelCache();
+        if (cache.size() > 0) {
+            auto data = new uint8_t [cache.size()];
+            *size = cache.size();
+            memcpy(data, cache.data(), cache.size());
+            return data;
+        }
+    }
+}
+
+TFL_CAPI_EXPORT uint8_t* TfLiteGpuDelegateGetModelCache(const TfLiteNode& node,
+                                                        size_t* size,
+                                                        bool delete_after) {
+    auto delegate = reinterpret_cast<tflite::gpu::DelegateKernel*>(node.user_data);
+    if (delegate) {
+        auto cache = delegate->GetSerializedModelCache();
+        if (cache.size() > 0) {
+            auto data = new uint8_t [cache.size()];
+            *size = cache.size();
+            memcpy(data, cache.data(), cache.size());
+            if (delete_after) {
+                delegate->DeleteSerializedModelCache();
+            }
+            return data;
+        }
+    }
+    return nullptr;
+}
+
+TFL_CAPI_EXPORT bool TfLiteGpuDelegateOpenCLSupported() {
+    return tflite::gpu::cl::OpenCLSupported();
+}
+
+TFL_CAPI_EXPORT const char* TfLiteGpuDelegateOpenCLVersion(size_t* size) {
+    *size = 0;
+    tflite::gpu::cl::CLDevice gpu;
+    if (tflite::gpu::cl::CreateDefaultGPUDevice(&gpu).ok()) {
+        auto error = tflite::gpu::cl::clGetDeviceInfo(gpu.id(), CL_DRIVER_VERSION, 0, nullptr, size);
+        if (error != CL_SUCCESS) {
+            return nullptr;
+        }
+        auto str = new char[*size];
+        str[*size - 1] = 0;
+        error = tflite::gpu::cl::clGetDeviceInfo(gpu.id(), CL_DRIVER_VERSION, *size, str, nullptr);
+        if (error != CL_SUCCESS) {
+            delete[] str;
+            return nullptr;
+        }
+        (*size)--;
+        return str;
+    }
+    return nullptr;
+}
