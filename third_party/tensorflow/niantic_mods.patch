   // This limits the maximum number of partitions to be delegated. By default,
   // it's set to 1 in TfLiteGpuDelegateOptionsV2Default().
   int32_t max_delegated_partitions;
+
+  // The buffer for the kernel cache to load into OpenCL if supported and
+  // selected. If the kernel cache is valid, the start up time will avoid
+  // compiling kernels that can be found in the cache. If the cache is invalid,
+  // it will be ignored.
+  uint8_t *serialized_kernel_cache;
+
+  // The buffer size for the kernel cache
+  int64_t serialized_kernel_cache_size;
+
+  // Tells the system to cache the model cache to be queried after the
+  // delegate is setup. The model cache is usually fairly large compared to
+  // the kernel cache, so holding the cache in memory each run should be avoided.
+  bool hold_model_cache;
+
+  // The buffer for the model cache to load into OpenCL if supported and
+  // selected. If the model cache is valid, the start up time will avoid
+  // setting up the OpenCL environment and skip tuning for device.
+  // If the cache is invalid, it will fail to create the model and could
+  // crash.
+  uint8_t *serialized_model_cache;
+
+  // The buffer size for the kernel cache
+  int64_t serialized_model_cache_size;
 } TfLiteGpuDelegateOptionsV2;
 
