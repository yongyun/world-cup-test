+                                                        bool delete_after = false);
+
+// Determine if OpenCL is supported by device with TensorFlow
+TFL_CAPI_EXPORT bool TfLiteGpuDelegateOpenCLSupported();
+
+// Gets the full OpenCL driver version. The string must be deleted after use as
