From cfb56f7b49723b52f5091618dc95dad4175cd0eb Mon Sep 17 00:00:00 2001
From: Filippo Trimoldi <filippotrimoldi@nianticlabs.com>
Date: Tue, 16 Aug 2022 14:03:44 +0100
Subject: [PATCH 1/5] Support for including in bazel 5.2.0 projects

---
 BUILD        |  2 +-
 protobuf.bzl | 16 +++++++---------
 2 files changed, 8 insertions(+), 10 deletions(-)

diff --git a/BUILD b/BUILD
index 0941d8c43..966dfcf9b 100644
--- a/BUILD
+++ b/BUILD
@@ -29,7 +29,7 @@ LINK_OPTS = select({
 })
 
 load(
-    "protobuf",
+    ":protobuf.bzl",
     "cc_proto_library",
     "py_proto_library",
     "internal_copied_filegroup",
diff --git a/protobuf.bzl b/protobuf.bzl
index c5555fde8..358d074bf 100644
--- a/protobuf.bzl
+++ b/protobuf.bzl
@@ -67,7 +67,7 @@ def _proto_gen_impl(ctx):
     args += ["--grpc_out=" + ctx.var["GENDIR"] + "/" + gen_dir]
 
   if args:
-    ctx.action(
+    ctx.actions.run(
         inputs=srcs + deps,
         outputs=ctx.outputs.outs,
         arguments=args + import_flags + [s.path for s in srcs],
@@ -88,15 +88,13 @@ _proto_gen = rule(
         "deps": attr.label_list(providers = ["proto"]),
         "includes": attr.string_list(),
         "protoc": attr.label(
-            cfg = HOST_CFG,
+            cfg = "host",
             executable = True,
-            single_file = True,
             mandatory = True,
         ),
         "grpc_cpp_plugin": attr.label(
-            cfg = HOST_CFG,
+            cfg = "host",
             executable = True,
-            single_file = True,
         ),
         "gen_cc": attr.bool(),
         "gen_py": attr.bool(),
@@ -183,9 +181,9 @@ def cc_proto_library(
   )
 
   if default_runtime and not default_runtime in cc_libs:
-    cc_libs += [default_runtime]
+    cc_libs = cc_libs + [default_runtime]
   if use_grpc_plugin:
-    cc_libs += ["//external:grpc_lib"]
+    cc_libs = cc_libs + ["//external:grpc_lib"]
 
   native.cc_library(
       name=name,
@@ -201,7 +199,7 @@ def internal_gen_well_known_protos_java(srcs):
   Args:
     srcs: the well known protos
   """
-  root = Label("%s//protobuf_java" % (REPOSITORY_NAME)).workspace_root
+  root = Label("%s//protobuf_java" % (native.repository_name())).workspace_root
   if root == "":
     include = " -Isrc "
   else:
@@ -298,7 +296,7 @@ def py_proto_library(
   )
 
   if default_runtime and not default_runtime in py_libs + deps:
-    py_libs += [default_runtime]
+    py_libs = py_libs + [default_runtime]
 
   native.py_library(
       name=name,
-- 
