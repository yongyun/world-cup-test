From a3aaed3a4b3cc049798c00b4f147943f9eb0dde4 Mon Sep 17 00:00:00 2001
From: Filippo Trimoldi <filippotrimoldi@nianticlabs.com>
Date: Fri, 26 Aug 2022 13:33:17 +0200
Subject: [PATCH 4/5] Added first support for generating CSharp proto
 interfaces

---
 protobuf.bzl | 59 ++++++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 59 insertions(+)

diff --git a/protobuf.bzl b/protobuf.bzl
index 823b3b287..76c34a564 100644
--- a/protobuf.bzl
+++ b/protobuf.bzl
@@ -1,5 +1,7 @@
 # -*- mode: python; -*- PYTHON-PREPROCESSING-REQUIRED
 
+load("@bazel_skylib//lib:paths.bzl", "paths")
+
 def _GetPath(ctx, path):
   if ctx.label.workspace_root:
     return ctx.label.workspace_root + '/' + path
@@ -26,6 +28,12 @@ def _CcOuts(srcs, use_grpc_plugin=False):
 def _PyOuts(srcs):
   return [s[:-len(".proto")] + "_pb2.py" for s in srcs]
 
+def _CsharpOuts(srcs):
+    print(["".join([token.capitalize() for token in src[:-len(".proto")].split("_")]) + ".cs" for src in srcs])
+    return [
+        "".join([token.capitalize() for token in src[:-len(".proto")].split("_")]) + ".cs"
+    for src in srcs]
+
 def _RelativeOutputPath(path, include, dest=""):
   if include == None:
     return path
@@ -61,6 +69,9 @@ def _proto_gen_impl(ctx):
     args += ["--cpp_out=" + ctx.var["GENDIR"] + "/" + gen_dir]
   if ctx.attr.gen_py:
     args += ["--python_out=" + ctx.var["GENDIR"] + "/" + gen_dir]
+  if ctx.attr.gen_csharp:
+    gen_dir = ctx.attr.csharp_package
+    args += ["--csharp_out=" + ctx.var["GENDIR"] + "/" + gen_dir]
 
   if ctx.executable.grpc_cpp_plugin:
     args += ["--plugin=protoc-gen-grpc=" + ctx.executable.grpc_cpp_plugin.path]
@@ -98,7 +109,9 @@ _proto_gen = rule(
         ),
         "gen_cc": attr.bool(),
         "gen_py": attr.bool(),
+        "gen_csharp": attr.bool(),
         "outs": attr.output_list(),
+        "csharp_package": attr.string()
     },
     output_to_genfiles = True,
     implementation = _proto_gen_impl,
@@ -305,6 +318,52 @@ def py_proto_library(
       imports=includes,
       **kargs)
 
+def csharp_proto_library_gen(
+        name,
+        package,
+        srcs=[],
+        deps=[],
+        include=None,
+        protoc="//:protoc",
+        **kargs):
+  """Bazel rule to create a CSharp protobuf file
+
+  NOTE: 
+  - It does not support grpc and it support one C# package at this time
+  - It requires the bazel package of the generated file 
+  - It does not allow to pass more protofile in different directories
+
+  Args:
+    name: the name of the py_proto_library.
+    package: the output bazel package (this should be removed later and automatically inferred)
+    srcs: the .proto files of the py_proto_library.
+    deps: a list of dependency labels; must be py_proto_library.
+    include: a string indicating the include path of the .proto files.
+    protoc: the label of the protocol compiler to generate the sources.
+  """
+  includes = []
+  if include != None:
+    includes = [include]
+
+  first_path = paths.dirname(srcs[0])
+  for src in srcs:
+    if first_path != paths.dirname(src):
+        fail("All srcs file for csharp_proto_library_gen must me in same package, but got " + ",".join([srcs]) + " that are in different packages.")
+
+  outs = _CsharpOuts(srcs)
+
+  _proto_gen(
+      name=name + "",
+      srcs=srcs,
+      deps=[s + "_genproto" for s in deps],
+      includes=includes,
+      protoc=protoc,
+      gen_csharp=1,
+      outs=outs,
+      visibility=["//visibility:public"],
+      csharp_package=package,
+  )
+
 def internal_protobuf_py_tests(
     name,
     modules=[],
-- 
2.37.2


