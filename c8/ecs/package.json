{
  "name": "ecs",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@automerge/automerge": "^2.2.0-rc1",
    "@tweenjs/tween.js": "^18.6.4",
    "@types/node": "^16.18.36",
    "@types/three": "^0.166.0",
    "@types/three-nebula": "^10.0.4",
    "lodash-es": "^4.17.21",
    "process": "^0.11.10",
    "three": "https://cdn.8thwall.com/web/three/three-8w-0-md3cykn0.172.0.tgz",
    "three-mesh-bvh": "^0.8.2",
    "three-nebula": "^10.0.3",
    "uuid": "^9.0.0",
    "yoga-layout": "^3.1.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "ecs:prepare": "bazel build //c8/ecs:ecs-asm --config=wasm && cp -f ../../bazel-bin/c8/ecs/ecs-asm.js src/runtime",
    "test": "bazel test --test_output=errors //c8/ecs/... && bazel test --test_output=errors //c8/ecs/... --config=node",
    "runtime:serve": "webpack-dev-server -c webpack.runtime.js",
    "runtime:build": "npm run ecs:prepare && webpack -c webpack.runtime.js",
    "runtime:build:sourcemaps": "npm run ecs:prepare && webpack -c webpack.runtime.js --env=dev",
    "inliner": "./tools/inliner.sh",
    "refresh-definition": "bazel run //c8/ecs/gen:write --config=wasm",
    "prod8-release": "./tools/prod8-release.sh"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.9",
    "@types/css-font-loading-module": "^0.0.14",
    "@types/lodash-es": "^4.17.12",
    "@types/uuid": "^9.0.2",
    "@types/webxr": "^0.5.21",
    "babel-loader": "^9.1.3",
    "base64-js": "^1.5.1",
    "meshoptimizer": "^0.20.0",
    "patch-package": "^8.0.0",
    "ts-essentials": "^9.3.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
