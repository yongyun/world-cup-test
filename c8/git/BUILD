        "MODULARIZE=1",
        "EXPORT_NAME=G8",
        "EXPORTED_RUNTIME_METHODS=[FS,writeArrayToMemory,lengthBytesUTF8,stringToUTF8]",
        "ENVIRONMENT=worker",
        "FETCH=1",
        # The following are useful for debugging but commented out for production:
        # "ASSERTIONS=2",
        # "DISABLE_EXCEPTION_CATCHING=0",
        # "DISABLE_EXCEPTION_THROWING=0",
